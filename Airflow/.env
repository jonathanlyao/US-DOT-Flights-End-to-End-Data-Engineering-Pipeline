# =============================================================
# Airflow Environment Variables
# IMPORTANT: Fill in your actual credentials below.
# NEVER commit this file to Git. Add it to .gitignore.
# =============================================================\

# Snowflake
SNOWFLAKE_ACCOUNT=[Your Snowflake Account ID]
SNOWFLAKE_USER=[Your Snowflake Account Username]
SNOWFLAKE_PASSWORD=[Your Snowflake Account Password]
SNOWFLAKE_WAREHOUSE=DOT_FLIGHTS_WH
SNOWFLAKE_DATABASE=DOT_FLIGHTS
SNOWFLAKE_ROLE=ACCOUNTADMIN

# AWS (get these from AWS Console -> IAM -> Security credentials)
AWS_ACCESS_KEY_ID=[Your AWS Access Key]
AWS_SECRET_ACCESS_KEY=[Your AWS Access Key]
